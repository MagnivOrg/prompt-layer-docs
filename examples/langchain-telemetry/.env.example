# Required for LangChain/OpenAI calls.
OPENAI_API_KEY=

# Required for LangChain/Anthropic calls when LANGCHAIN_MODEL_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# Optional provider/model overrides.
# LANGCHAIN_MODEL_PROVIDER=openai
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional Anthropic effort. When set, the app enables adaptive thinking and
# passes this value directly to ChatAnthropic outputConfig.effort.
# Valid values: low, medium, high, xhigh, max.
ANTHROPIC_THINKING=medium

# Required for LangChain to emit spans automatically.
LANGSMITH_TRACING=true
LANGSMITH_TRACING_MODE=otel

# Recommended so spans flush before server action completion.
LANGCHAIN_CALLBACKS_BACKGROUND=false

# Optional: enable OTEL export to PromptLayer.
# If OTEL_EXPORTER_OTLP_ENDPOINT is not set, trace export is disabled.
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.promptlayer.com/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=X-API-KEY=<PROMPTLAYER_API_KEY>
