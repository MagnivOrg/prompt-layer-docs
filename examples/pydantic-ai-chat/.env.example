# Required for Anthropic model calls.
ANTHROPIC_API_KEY=

# Required for OpenAI model calls and the default embeddings demo.
OPENAI_API_KEY=

# Required for PromptLayer OTLP trace export.
PROMPTLAYER_API_KEY=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://api.promptlayer.com/v1/traces

# Optional defaults.
OTEL_SERVICE_NAME=pydantic-ai-promptlayer-demo
PYDANTIC_AI_MODEL=anthropic:claude-sonnet-4-6
PYDANTIC_AI_THINKING=medium
PYDANTIC_AI_EMBEDDING_MODEL=openai:text-embedding-3-small
SEND_TO_LOGFIRE=false
ENABLE_HTTPX_CAPTURE=false
